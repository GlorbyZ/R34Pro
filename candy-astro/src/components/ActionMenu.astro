---
---
<div class="w-[450px] flex-shrink-0 flex flex-col glass-card rounded-2xl max-h-[820px] overflow-hidden shadow-2xl">
    <div class="p-6 flex flex-col gap-6 overflow-y-auto scrollbar-none">
        <!-- Header -->
        <div class="flex items-center justify-between pb-4 border-b border-white/5">
            <div class="flex flex-col">
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 bg-accent rounded-full animate-pulse shadow-[0_0_8px_#FFD700]"></div>
                    <span class="font-orbitron text-xs font-black tracking-widest text-accent italic">COMMAND_INTERFACE_V3</span>
                </div>
                <span class="text-[10px] text-white/30 font-bold mt-1">SECURE_CHANNEL_LOCAL_HOST</span>
            </div>
            <div class="px-3 py-1 bg-primary/20 border border-primary/40 rounded text-[10px] font-black text-primary">LIVE</div>
        </div>

        <!-- Sync Progress -->
        <div class="bg-black/40 p-5 rounded-xl border border-white/5 relative group overflow-hidden">
            <div class="flex items-center justify-between mb-4 relative z-10">
                <div class="flex items-center gap-4">
                    <!-- Tech Ring -->
                    <div class="relative w-14 h-14">
                        <svg class="w-full h-full -rotate-90" viewBox="0 0 38 38">
                            <circle cx="19" cy="19" r="16" stroke="rgba(255,255,255,0.05)" stroke-width="2" fill="none" />
                            <circle 
                                id="xp-circle"
                                cx="19" 
                                cy="19" 
                                r="16" 
                                stroke="#FF3B3B" 
                                stroke-width="2" 
                                fill="none" 
                                stroke-dasharray="100.5 100.5" 
                                stroke-dashoffset="100.5" 
                                stroke-linecap="square"
                                class="transition-all duration-1000 ease-in-out shadow-primary shadow-lg"
                            />
                        </svg>
                        <div class="absolute inset-0 flex flex-col justify-center items-center">
                            <span id="level-badge" class="text-lg font-black font-orbitron text-white leading-none">01</span>
                            <span class="text-[7px] font-black text-primary uppercase">SYNC_LEVEL</span>
                        </div>
                    </div>
                    <div>
                        <div class="text-white font-orbitron text-sm font-black italic tracking-wider">NEURAL_SYNC</div>
                        <div class="text-[10px] text-primary font-bold uppercase tracking-widest mt-1">Status: Stable</div>
                    </div>
                </div>
                
                <button class="bg-accent/10 border border-accent/40 text-accent text-[9px] font-black px-3 py-2 rounded uppercase tracking-tighter hover:bg-accent/30 transition-all">
                    Overclock >
                </button>
            </div>
            
            <div class="w-full bg-white/5 rounded-none h-1.5 mb-2 overflow-hidden border border-white/5">
                <div id="xp-bar" class="primary-gradient h-full w-[0%] transition-all duration-1000 shadow-[0_0_15px_#FF3B3B]"></div>
            </div>
            
            <div class="flex justify-between text-[8px] text-white/30 font-black uppercase tracking-[0.2em]">
                <span id="xp-counter">0000 / 1000 BP</span>
                <span>SYNC_TARGET_100%</span>
            </div>
        </div>

        <!-- Override Commands -->
        <div class="flex flex-col gap-3">
            <div class="text-[10px] font-black text-white/20 uppercase tracking-[0.3em] mb-1">Available Overrides</div>
            {[
                { name: 'Initialize Physical Tease', key: 'tease', level: 1 },
                { name: 'Core Sentiment Override', key: 'action', level: 1 },
                { name: 'Subsystem Access: Level 2', key: 'lock', level: 2, locked: true }
            ].map((action) => (
                <button 
                    class={`flex items-center px-5 py-4 rounded-lg border transition-all relative group ${
                        action.locked ? 'bg-black/20 border-white/5 opacity-40 grayscale cursor-not-allowed' : 
                        'bg-white/[0.03] border-white/10 hover:border-primary/50 hover:bg-primary/5 active:scale-[0.98]'
                    }`}
                    data-action-key={action.key}
                    data-action-name={action.name}
                    data-locked={action.locked}
                >
                    <div class="flex-1 flex flex-col items-start relative z-10">
                        <span class="text-[11px] font-black font-orbitron tracking-widest text-white/90 group-hover:text-primary transition-colors">
                            {action.name.toUpperCase()}
                        </span>
                        <span class="text-[8px] text-white/30 font-bold mt-1">ACCESS_GRANTED // LVL_{action.level}</span>
                    </div>
                    {!action.locked && (
                        <div class="w-8 h-8 rounded border border-primary/20 flex items-center justify-center group-hover:border-primary group-hover:bg-primary/10 transition-all">
                            <svg class="w-4 h-4 text-primary translate-x-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                        </div>
                    )}
                </button>
            ))}

            <!-- Full Access Prompt -->
            <div class="mt-4 p-6 glass-card rounded-xl relative overflow-hidden group">
                 <div class="absolute -right-10 -top-10 w-40 h-40 bg-primary/10 rounded-full blur-[40px] group-hover:bg-primary/20 transition-all"></div>
                 <h4 class="font-orbitron font-black text-sm text-primary mb-2 italic tracking-tighter">UNRESTRICTED ACCESS</h4>
                 <p class="text-[10px] text-white/40 font-medium leading-relaxed mb-5">By-pass security protocols and access the full suite of cyber-companion capabilities.</p>
                 <button class="w-full py-4 primary-gradient rounded text-[11px] font-black uppercase tracking-widest text-white shadow-xl hover:neon-glow transition-all">
                    Establish Full Link
                 </button>
            </div>
        </div>
    </div>
</div>

<script>
    class ActionController {
        constructor() {
            this.xp = 0;
            this.level = 1;
            this.xpPerLevel = 100;
            
            this.bar = document.getElementById('xp-bar');
            this.circle = document.getElementById('xp-circle');
            this.counter = document.getElementById('xp-counter');
            this.badge = document.getElementById('level-badge');
            
            this.init();
        }

        init() {
            document.querySelectorAll('[data-action-key]').forEach(el => {
                el.addEventListener('click', () => {
                    const { actionKey, actionName, locked } = el.dataset;
                    if (locked === 'true') return;
                    
                    window.dispatchEvent(new CustomEvent('trigger-action', { 
                        detail: { key: actionKey, name: actionName } 
                    }));
                });
            });

            window.addEventListener('update-xp', (e) => this.addXp(e.detail.amount || 15));
            this.updateUI();
        }

        addXp(amount) {
            this.xp += amount;
            if (this.xp >= this.xpPerLevel) {
                this.xp = this.xp % this.xpPerLevel;
                this.level++;
                this.playLevelUp();
            }
            this.updateUI();
        }

        playLevelUp() {
            const badge = this.badge;
            this.badge.classList.add('text-primary');
            setTimeout(() => this.badge.classList.remove('text-primary'), 1000);
        }

        updateUI() {
            const percent = (this.xp / this.xpPerLevel) * 100;
            if (this.bar) this.bar.style.width = `${percent}%`;
            if (this.circle) {
                const circ = 100.5;
                this.circle.style.strokeDashoffset = (circ - (percent / 100) * circ).toString();
            }
            if (this.counter) this.counter.textContent = `${this.xp.toString().padStart(4, '0')} / ${this.xpPerLevel} BP`;
            if (this.badge) this.badge.textContent = this.level.toString().padStart(2, '0');
        }
    }

    document.addEventListener('DOMContentLoaded', () => new ActionController());
</script>
