<div class="fixed top-0 z-[100] bg-black/80 backdrop-blur-xl w-full flex md:h-[64px] h-[53px] shrink-0 items-center border-b border-white/5 sm:px-4 px-2 shadow-2xl gap-x-2 lg:px-8">
    <button id="nav-toggle" class="p-2 text-primary hover:scale-110 transition-transform">
