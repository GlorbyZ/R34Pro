---
<div 
  id="sidebar-closed"
  class="lg:fixed lg:pt-[64px] z-[50] border-[#363636] border-r border-t lg:inset-y-0 lg:left-0 lg:w-[100px] lg:pb-5 w-[100px] fixed top-0 left-0 h-full webkit-transition-sidebar webkit-transform-sidebar bg-[#131313] overflow-hidden group/sidebar"
>
  <nav class="flex flex-col justify-between h-full">
    <div class="flex flex-col">
      <ul class="py-8 lg:py-6 flex flex-col gap-4 items-center px-6">
        {[
            { id: 'home', label: 'Home', icon: '🏠' },
            { id: 'explore', label: 'Discover', icon: '🔍' },
            { id: 'chat', label: 'Chat', icon: '💬' },
            { id: 'gallery', label: 'Collection', icon: '🖼️' },
            { id: 'magic-wand', label: 'Create', icon: '🪄' },
            { id: 'love-lady', label: 'My AI', icon: '👤' }
        ].map((item) => (
          <li class="relative w-full group">
            <div class="h-[48px] w-full hover:bg-zinc-700 rounded-[10px] border border-white/10 flex justify-start px-[11px] items-center gap-4 cursor-pointer transition-all">
              <div class="w-6 h-6 shrink-0 flex items-center justify-center text-lg">{item.icon}</div>
              <span class="text-grey-medium font-medium text-sm hidden whitespace-nowrap overflow-hidden transition-all group-hover:text-white">{item.label}</span>
            </div>
          </li>
        ))}

        <!-- Premium Button -->
        <li class="w-full mt-2">
            <div class="h-[48px] w-full rounded-[10px] border border-white/10 bg-gradient-to-t from-primary/20 to-transparent flex items-center px-[11px] gap-4 cursor-pointer group">
                <div class="w-6 h-6 shrink-0 flex items-center justify-center text-lg group-hover:animate-bounce">💎</div>
                <span class="text-primary font-bold text-sm hidden">FULL_ACCESS</span>
            </div>
        </li>
      </ul>
    </div>
    
    <ul class="flex flex-col gap-4 pt-6 px-6 border-[#363636] border-t items-center justify-end">
        <li class="w-full">
            <button class="h-[48px] w-full border border-white/10 rounded-[10px] hover:bg-zinc-700 flex justify-center items-center px-[11px] gap-4 transition-all overflow-hidden group">
                <span class="text-lg shrink-0">🌐</span>
                <span class="text-xs font-bold text-grey-medium hidden group-hover:text-white">English</span>
            </button>
        </li>
    </ul>
  </nav>
</div>

<script>
    // Logic to show labels when sidebar is "opened" via global state
    // We'll use CSS for the layout, but some JS if needed
</script>

<style>
    /* CSS logic for sidebar expansion */
    body[data-sidebar-opened="true"] #sidebar-closed {
        width: 220px !important;
    }
    
    body[data-sidebar-opened="true"] #sidebar-closed span {
        display: inline-block !important;
        animation: fadeIn 0.2s forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>
