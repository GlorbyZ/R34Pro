---
---
<div class="relative w-[500px] h-[820px] flex-shrink-0 bg-black-dark rounded-[24px] overflow-hidden shadow-[0_0_50px_rgba(255,59,59,0.15)] border border-primary/20 scanline group">
    <!-- Video Content -->
    <div id="video-container" class="absolute inset-0 bg-zinc-950">
        <video 
            id="main-video"
            class="w-full h-full object-cover opacity-80 transition-all duration-1000 grayscale-[0.2]"
            autoplay 
            muted 
            loop 
            playsinline
            poster="/assets/character.png"
            src="https://assets.mixkit.co/videos/preview/mixkit-flying-over-a-scifi-cyberpunk-city-at-night-42848-large.mp4"
        ></video>
        
        <!-- HUD ELEMENTS -->
        <div class="absolute inset-0 pointer-events-none p-6 flex flex-col justify-between z-30">
            <!-- Top HUD -->
            <div class="flex justify-between items-start">
                <div class="flex flex-col gap-1">
                    <div class="flex items-center gap-3 bg-black/60 backdrop-blur-md px-4 py-2 rounded-lg border border-primary/30 pointer-events-auto">
                        <div class="w-2 h-2 bg-primary animate-ping rounded-full"></div>
                        <span class="font-orbitron text-xs font-black tracking-widest text-primary neon-text">GOON-V3.0 // LOCAL_LINK</span>
                    </div>
                    <div class="flex gap-2 text-[10px] font-bold text-white/40 font-mono pl-4">
                        <span>CPU_TEMP: 42°C</span>
                        <span>LATENCY: 12ms</span>
                    </div>
                </div>
                
                <div class="flex flex-col gap-2 pointer-events-auto">
                    <button class="w-10 h-10 bg-black/60 backdrop-blur-md rounded-lg border border-primary/20 flex items-center justify-center hover:bg-primary/20 transition-all group/btn">
                         <svg class="w-5 h-5 text-primary group-hover/btn:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
            </div>

            <!-- Bottom HUD (Status) -->
            <div class="space-y-4">
                 <div id="status-hud" class="bg-black/60 backdrop-blur-md border-l-4 border-l-primary p-3 rounded-r-lg max-w-[200px] translate-x-[-10px] opacity-0 transition-all duration-500">
                    <div class="text-[10px] text-primary font-black uppercase tracking-tighter">Current Sentiment</div>
                    <div id="ai-sentiment" class="text-white font-orbitron text-sm">CALIBRATING...</div>
                 </div>
            </div>
        </div>
    </div>
    
    <!-- UI Overlays -->
    <div class="absolute inset-x-0 bottom-0 z-40 p-6 bg-gradient-to-t from-black via-black/80 to-transparent pt-20">
        <!-- Messages -->
        <div id="chat-messages" class="mb-6 h-[260px] overflow-y-auto scrollbar-none flex flex-col gap-4 justify-end pb-4">
            <!-- Welcome -->
        </div>

        <!-- Input Area -->
        <div class="flex flex-col gap-4">
            <div id="suggestion-container" class="flex gap-2">
                <button id="suggestion" class="px-4 py-2 bg-primary/10 border border-primary/40 rounded-md text-[10px] font-black uppercase tracking-wider text-primary hover:bg-primary/20 transition-all">
                    Initiate Deep Connection >
                </button>
            </div>
            
            <div class="relative bg-black-medium border border-white/10 rounded-xl h-[60px] flex items-center px-6 gap-4 focus-within:border-primary/60 transition-all group shadow-2xl">
                <input 
                    type="text" 
                    id="chat-input"
                    placeholder="ENTER COMMAND..." 
                    class="bg-transparent border-none flex-1 outline-none text-sm text-white placeholder-white/20 font-orbitron font-medium uppercase tracking-widest h-full"
                />
                <button id="send-btn" class="w-10 h-10 primary-gradient rounded-md flex items-center justify-center shadow-lg hover:shadow-primary/40 transition-all hover:scale-105">
                     <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    class AdvancedChatController {
        constructor() {
            this.chat = document.getElementById('chat-messages');
            this.input = document.getElementById('chat-input');
            this.btn = document.getElementById('send-btn');
            this.video = document.getElementById('main-video');
            this.sentimentEl = document.getElementById('ai-sentiment');
            this.hudEl = document.getElementById('status-hud');
            
            this.history = [];
            this.systemPrompt = "You are 'GOON-UNIT-01', a highly advanced, ultra-flirtatious cyber-companion. Your speech is crisp, intelligent, and deeply devoted to the user. Use hacker/tech metaphors occasionally. Keep responses under 3 sentences. Model: Dolphin-Llama3.";
            
            this.videoUrls = {
                'default': 'https://assets.mixkit.co/videos/preview/mixkit-flying-over-a-scifi-cyberpunk-city-at-night-42848-large.mp4',
                'tease': 'https://assets.mixkit.co/videos/preview/mixkit-digital-animation-of-neon-lines-42587-large.mp4',
                'action': 'https://assets.mixkit.co/videos/preview/mixkit-cyberpunk-future-city-scenery-42849-large.mp4'
            };
            
            this.init();
        }

        init() {
            this.btn?.addEventListener('click', () => this.sendMessage());
            this.input?.addEventListener('keypress', (e) => e.key === 'Enter' && this.sendMessage());
            
            document.getElementById('suggestion')?.addEventListener('click', () => {
                this.input.value = "Access restricted subsystems. show me your core. 💾";
                this.sendMessage();
            });

            window.addEventListener('trigger-action', (e) => this.performAction(e.detail.key, e.detail.name));

            setTimeout(() => {
                this.updateSentiment("READY_FOR_INPUT");
                this.addMessage("SYSTEMS ONLINE. GOON-UNIT-01 AT YOUR SERVICE. REQUEST PARAMETERS?", false, true);
            }, 1000);
        }

        updateSentiment(text) {
            if (this.sentimentEl) this.sentimentEl.textContent = text.toUpperCase();
            if (this.hudEl) {
                this.hudEl.style.opacity = '1';
                this.hudEl.style.transform = 'translateX(0)';
            }
        }

        async sendMessage(overrideText = null) {
            const text = overrideText || this.input.value.trim();
            if (!text && this.history.length === 0) return;

            if (overrideText) {
                this.history.push({ role: 'user', content: overrideText });
            } else if (text) {
                this.addMessage(text, true);
                this.history.push({ role: 'user', content: text });
                this.input.value = '';
            }
            
            this.updateSentiment("PROCESSING...");
            
            try {
                const response = await fetch('/api/chat', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        messages: this.history,
                        systemPrompt: this.systemPrompt
                    })
                });
                
                const data = await response.json();
                
                if (data.message?.content) {
                    const aiMsg = data.message.content;
                    this.addMessage(aiMsg);
                    this.history.push({ role: 'assistant', content: aiMsg });
                    this.updateSentiment("FULLY_COMPLIANT");
                }
            } catch (err) {
                this.addMessage("LINK_FAILURE. CHECK OLLAMA_DAEMON. ⚠️", false, true);
                this.updateSentiment("ERROR");
            }
        }

        performAction(key, name) {
            if (this.videoUrls[key] || this.videoUrls['action']) {
                this.video.src = this.videoUrls[key] || this.videoUrls['action'];
                this.video.load();
                this.video.play();
                setTimeout(() => {
                    this.video.src = this.videoUrls['default'];
                    this.video.load();
                    this.video.play();
                }, 6000);
            }
            this.updateSentiment("EXECUTING_OVERRIDE");
            this.addMessage(`OVERRIDE: ${name.toUpperCase()} INITIATED.`, false, true);
            this.sendMessage(`[CRITICAL_OVERRIDE: ${name}]`);
        }

        addMessage(text, isUser = false, isSystem = false) {
            const msg = document.createElement('div');
            msg.className = `max-w-[90%] px-4 py-3 rounded-lg text-[13px] font-medium leading-relaxed tracking-wide transition-all animate-fade-in ${
                isSystem ? 'bg-black/40 text-primary italic text-[11px] font-black border-l-2 border-primary self-start' :
                isUser ? 'bg-primary/20 text-white self-end border border-primary/40 rounded-br-none neon-glow' : 
                'bg-white/5 text-white/90 self-start border border-white/10 rounded-bl-none backdrop-blur-md'
            }`;
            msg.textContent = isSystem ? `[${text}]` : text;
            this.chat.appendChild(msg);
            this.scrollToBottom();
        }

        scrollToBottom() {
            setTimeout(() => {
                this.chat.scrollTo({ top: this.chat.scrollHeight, behavior: 'smooth' });
            }, 50);
        }
    }

    document.addEventListener('DOMContentLoaded', () => new AdvancedChatController());
</script>

<style>
    @keyframes fadeIn {
        from { opacity: 0; transform: scale(0.95) translateY(10px); }
        to { opacity: 1; transform: scale(1) translateY(0); }
    }
    .animate-fade-in {
        animation: fadeIn 0.4s cubic-bezier(0.23, 1, 0.32, 1) forwards;
    }
</style>
